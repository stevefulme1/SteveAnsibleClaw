#!/usr/bin/env bash
# run.sh -- Wrapper for ansible {{ module_name }}
# Generated by AnsibleClaw
set -euo pipefail

MODULE="{{ module_name }}"
USAGE="Usage: $(basename "$0") <host-pattern> [module-args] [options]

Run the $MODULE Ansible module against target hosts.

Arguments:
  host-pattern    Target hosts (e.g., webservers, all, myhost.example.com,)
  module-args     Module arguments as key=value pairs (quoted)

Options:
  --apply         Actually apply changes (default is dry-run with --check --diff)
  -i PATH         Inventory file path
  -b              Run with become/sudo (enabled by default)
  --no-become     Disable become/sudo
  -l PATTERN      Limit to specific hosts
  -h, --help      Show this help message

Examples:
  $(basename "$0") webservers \"{{ example_args }}\"
  $(basename "$0") webservers \"{{ example_args }}\" --apply
  $(basename "$0") webservers \"{{ example_args }}\" -i /path/to/hosts.yml
"

HOSTS=""
ARGS=""
APPLY=false
BECOME=true
EXTRA_FLAGS=()

while [[ $# -gt 0 ]]; do
    case "$1" in
        -h|--help)
            echo "$USAGE"
            exit 0
            ;;
        --apply)
            APPLY=true
            shift
            ;;
        --no-become)
            BECOME=false
            shift
            ;;
        -i|-l)
            EXTRA_FLAGS+=("$1" "$2")
            shift 2
            ;;
        -*)
            EXTRA_FLAGS+=("$1")
            shift
            ;;
        *)
            if [[ -z "$HOSTS" ]]; then
                HOSTS="$1"
            else
                ARGS="$1"
            fi
            shift
            ;;
    esac
done

if [[ -z "$HOSTS" ]]; then
    echo "Error: host-pattern is required." >&2
    echo "$USAGE" >&2
    exit 1
fi

CMD=(ansible "$HOSTS" -m "$MODULE")

if [[ -n "$ARGS" ]]; then
    CMD+=(-a "$ARGS")
fi

if [[ "$BECOME" == true ]]; then
    CMD+=(-b)
fi

if [[ "$APPLY" == false ]]; then
    CMD+=(--check --diff)
    echo "==> Dry-run mode (pass --apply to execute for real)"
else
    CMD+=(--diff)
    echo "==> Applying changes"
fi

CMD+=("${EXTRA_FLAGS[@]}")

echo "==> ${CMD[*]}"
exec "${CMD[@]}"
