#!/usr/bin/env bash
# check.sh -- Prerequisite check for {{ module_name }}
# Generated by AnsibleClaw
set -euo pipefail

MODULE="{{ module_name }}"
{% set ns_parts = module_name.split('.') %}
{% if ns_parts | length >= 3 and ns_parts[0] != 'ansible' %}
COLLECTION="{{ ns_parts[0] }}.{{ ns_parts[1] }}"
{% else %}
COLLECTION=""
{% endif %}
PASS=0
FAIL=0

check() {
    local label="$1"
    shift
    if "$@" > /dev/null 2>&1; then
        echo "  [PASS] $label"
        PASS=$((PASS + 1))
    else
        echo "  [FAIL] $label"
        FAIL=$((FAIL + 1))
    fi
}

echo "Checking prerequisites for $MODULE ..."
echo

check "ansible CLI is installed" command -v ansible
check "ansible-doc CLI is installed" command -v ansible-doc
check "Module $MODULE is available" ansible-doc -t module "$MODULE"

if [[ -n "$COLLECTION" ]]; then
    check "Collection $COLLECTION is installed" \
        bash -c "ansible-galaxy collection list 2>/dev/null | grep -q '$COLLECTION'"
fi

echo
echo "Results: $PASS passed, $FAIL failed"

if [[ $FAIL -gt 0 ]]; then
    echo
{% if ns_parts | length >= 3 and ns_parts[0] != 'ansible' %}
    echo "To fix:"
    echo "  pip install ansible-core        # install Ansible"
    echo "  ansible-galaxy collection install {{ ns_parts[0] }}.{{ ns_parts[1] }}  # install collection"
{% else %}
    echo "To fix:"
    echo "  pip install ansible-core        # install Ansible"
{% endif %}
    exit 1
fi
